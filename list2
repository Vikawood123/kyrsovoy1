from django.db import models


class Document(models.Model):
    name = models.TextField()

    class Meta:
        managed = False
        db_table = 'document'


class Dogovor(models.Model):
    rowid = models.IntegerField(primary_key=True, db_column='rowid')
    proforg = models.TextField(db_column='profORG', blank=True, null=True)
    adress = models.TextField(blank=True, null=True)
    smart = models.TextField(blank=True, null=True)
    rec = models.TextField(blank=True, null=True)
    ryco = models.TextField(blank=True, null=True)
    # Дополнительные поля для практики
    practice_type = models.CharField(max_length=50, blank=True, null=True, verbose_name='Вид практики')
    course = models.IntegerField(blank=True, null=True, verbose_name='Курс')
    group_name = models.CharField(max_length=50, blank=True, null=True, verbose_name='Группа')
    practice_start_date = models.CharField(max_length=50, blank=True, null=True, verbose_name='Дата начала практики')
    practice_end_date = models.CharField(max_length=50, blank=True, null=True, verbose_name='Дата окончания практики')

    class Meta:
        managed = False
        db_table = 'dogovor'


